// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  publicKey    String      @unique
  role         String      @default("CLIENT")
  suspended    Boolean     @default(false)
  name         String?
  createdAt    DateTime    @default(now())
  events       SaleEvent[]
}

model SaleEvent {
  id           String   @id @default(cuid())
  clientId     String
  name         String
  stockCount   Int
  rateLimit                  Int      @default(50)
  oversubscriptionMultiplier Float    @default(1.5)
  status                     String   @default("PENDING")
  publicKey    String   @unique
  
  // RS256 keypair — replaces secretKey
  rsaPrivateKey  String   // PEM — signs JWTs, never leaves engine
  rsaPublicKey   String   // PEM — served via JWKS, clients verify with this
  
  // Separate HMAC secret purely for release route request signing
  // Kept as random bytes — no reason to use RSA for request authentication
  signingSecret  String
  
  webhookUrl   String?
  endedAt      DateTime?
  createdAt    DateTime @default(now())

  client    Client          @relation(fields: [clientId], references: [id])
  attempts  QueueAttempt[]
  releases  TicketRelease[]
  usedJtis  UsedJti[]
}

// QueueAttempt, TicketRelease, UsedJti — no changes

// Every join attempt logged — WON, LOST, or RATE_LIMITED
// Gives you analytics: how many people tried, how many won, drop-off rate
model QueueAttempt {
  id          String   @id @default(cuid())
  saleEventId String
  userId      String   // whatever the client passes as the user identifier
  result      String   // WON | LOST | RATE_LIMITED | SOLD_OUT
  jti         String?  // only populated if result = WON
  createdAt   DateTime @default(now())

  saleEvent   SaleEvent @relation(fields: [saleEventId], references: [id])

  @@index([saleEventId])  // you'll query this a lot for dashboards
  @@index([saleEventId, result])
}

// Audit log of every stock release (expired ticket, user cancelled)
model TicketRelease {
  id          String   @id @default(cuid())
  saleEventId String
  jti         String   // which ticket was returned
  reason      String   // EXPIRED | CANCELLED | PAYMENT_FAILED
  releasedAt  DateTime @default(now())

  saleEvent   SaleEvent @relation(fields: [saleEventId], references: [id])
}

// Engine-side double-spend shield
// When a client's backend verifies a JWT, they can optionally call your
// /api/verify endpoint which writes the jti here — prevents replay even
// if the client forgets to add @unique on their own side
model UsedJti {
  jti         String   @id   // the UUID from the JWT — PK guarantees uniqueness
  saleEventId String
  usedAt      DateTime @default(now())
  expiresAt   DateTime        // store this so you can clean up expired rows later

  saleEvent   SaleEvent @relation(fields: [saleEventId], references: [id])
}