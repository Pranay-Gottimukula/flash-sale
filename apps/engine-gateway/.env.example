DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

REDIS_URL="rediss://default:password@host:6379"

# Symmetric secret for signing dashboard auth JWTs (HS256).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET="change-me-to-a-long-random-secret"

# Legacy — kept for backwards compat, prefer AUTH_JWT_SECRET for new code
JWT_SECRET="change-me-in-production"

PORT=4000
ADMIN_SECRET="generate-a-strong-random-secret"
API_URL="http://localhost:4000"
ENGINE_URL="http://localhost:4000"

# Optional — used by prisma/seed.ts
SUPER_ADMIN_EMAIL="admin@flashengine.dev"
SUPER_ADMIN_PASSWORD="change-me-before-seeding"
