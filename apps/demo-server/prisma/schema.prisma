generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name     String     @db.VarChar(255)
  email         String     @unique @db.VarChar(255)
  password_hash String     @db.VarChar(255)
  role          user_role
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  addresses     Address[]
  comments      comments[]
  favorites     Favorite[]
  orders        Order[]    @relation("CustomerOrders")
  products      Product[]  @relation("SellerProducts")

  @@map("users")
}

model Address {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  street_address String    @db.VarChar(255)
  city           String    @db.VarChar(100)
  state          String    @db.VarChar(100)
  zip_code       String    @db.VarChar(20)
  is_default     Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders         Order[]

  @@map("addresses")
}

model Product {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id        String          @db.Uuid
  name             String          @db.VarChar(255)
  description      String
  image_urls       String[]
  original_mrp     Decimal         @db.Decimal(10, 2)
  discount_price   Decimal         @db.Decimal(10, 2)
  stock_qty        Int             @default(0)
  estimated_demand Int?            @default(0)
  max_qty_per_user Int             @default(1)
  status           product_status? @default(DRAFT)
  sale_starts_at   DateTime?       @db.Timestamptz(6)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  comments         comments[]
  favorites        Favorite[]
  order_items      OrderItem[]
  seller           User            @relation("SellerProducts", fields: [seller_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("products")
}

model Favorite {
  user_id    String    @db.Uuid
  product_id String    @db.Uuid
  added_at   DateTime? @default(now()) @db.Timestamptz(6)
  product    Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, product_id])
  @@index([added_at], map: "idx_favorites_added_at")
  @@map("favorites")
}

model Order {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id         String        @db.Uuid
  shipping_address_id String        @db.Uuid
  total_amount        Decimal       @db.Decimal(10, 2)
  status              order_status? @default(PENDING)
  created_at          DateTime?     @default(now()) @db.Timestamptz(6)
  items               OrderItem[]
  customer            User          @relation("CustomerOrders", fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  shipping_address    Address       @relation(fields: [shipping_address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("orders")
}

model OrderItem {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     String  @db.Uuid
  product_id   String  @db.Uuid
  quantity     Int
  locked_price Decimal @db.Decimal(10, 2)
  order        Order   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product      Product @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("order_items")
}

model comments {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String    @db.Uuid
  user_id    String    @db.Uuid
  content    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  products   Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_comments_product_id")
}

enum Role {
  SELLER
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  UPCOMING
  ACTIVE
  SOLD_OUT
  TERMINATED
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
}

enum order_status {
  PENDING
  COMPLETED
  FAILED
}

enum product_status {
  DRAFT
  UPCOMING
  ACTIVE
  SOLD_OUT
  TERMINATED
}

enum user_role {
  SELLER
  CUSTOMER
}
